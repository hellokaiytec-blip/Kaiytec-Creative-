            <button key={t} onClick={() => setTab(t)} style={{ display:"block", width:"100%", textAlign:"left", background: tab===t ? BRAND.green : "none", border:"none", cursor:"pointer", color: tab===t ? "#fff" : "rgba(255,255,255,0.45)", padding:"10px 14px", borderRadius:6, fontSize:12, textTransform:"capitalize", letterSpacing:"0.04em", fontWeight: tab===t ? 700 : 400, marginBottom:3, transition:"all 0.2s" }}>{t}</button>
