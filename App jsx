              {[["Concept Works","5","Published"],["Blog Posts","4","Published"],["Services","10","Active"],["Newsletter","—","Connected"]].map(([l,v,s]) => (
                <div key={l} style={{ background:"#1a1a1a", border:"1px solid rgba(255,255,255,0.06)", borderRadius:8, padding:"22px 18px" }}>
                  <div style={{ color:"rgba(255,255,255,0.35)", fontSize:10, letterSpacing:"0.18em", textTransform:"uppercase", marginBottom:8 }}>{l}</div>
                  <div style={{ fontSize:30, fontWeight:800, color: BRAND.green, marginBottom:3 }}>{v}</div>
                  <div style={{ fontSize:10, color:"rgba(255,255,255,0.25)", letterSpacing:"0.1em" }}>{s}</div>
                </div>
              ))}
            </div>
            <div style={{ background:"#1a1a1a", border:"1px solid rgba(10,90,47,0.2)", borderRadius:8, padding:"28px 24px" }}>
              <h3 style={{ fontSize:13, fontWeight:700, letterSpacing:"0.12em", textTransform:"uppercase", color: BRAND.green, marginBottom:14 }}>🔌 CMS Integration Guide</h3>
              <p style={{ fontFamily:"Georgia, serif", color:"rgba(255,255,255,0.55)", lineHeight:1.85, fontSize:13.5, fontStyle:"italic", marginBottom:16 }}>To connect a full no-code CMS, integrate Supabase using the provided schema below. This panel is pre-structured and ready for production backend integration.</p>
              <pre style={{ background:"rgba(0,0,0,0.3)", borderRadius:6, padding:"16px", fontSize:12, color:"rgba(255,255,255,0.5)", lineHeight:1.7, overflow:"auto" }}>{`// .env.local
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

// Supabase Tables:
// - concepts (id, slug, title, category, body, published)
// - blog_posts (id, slug, title, tag, body, published)  
// - newsletter_subscribers (id, email, created_at)
// - contact_submissions (id, name, email, service, message)
// - services (id, slug, title, description, active)`}</pre>
            </div>
          </div>
        )}

        {tab === "concepts" && (
          <div>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:28 }}>
              <h1 style={{ fontSize:22, fontWeight:800 }}>Concept Works</h1>
              <button style={{ background: BRAND.green, color:"#fff", border:"none", cursor:"pointer", padding:"9px 18px", borderRadius:4, fontWeight:700, fontSize:11, letterSpacing:"0.1em", textTransform:"uppercase" }}>+ Add Concept</button>
            </div>
            {CONCEPTS.map(c => (
              <div key={c.slug} style={{ background:"#1a1a1a", border:"1px solid rgba(255,255,255,0.06)", borderRadius:8, padding:"18px 22px", marginBottom:10, display:"flex", justifyContent:"space-between", alignItems:"center", flexWrap:"wrap", gap:10 }}>
                <div>
                  <div style={{ fontWeight:700, fontSize:14, marginBottom:3 }}>{c.title}</div>
                  <div style={{ fontSize:11, color:"rgba(255,255,255,0.35)", letterSpacing:"0.1em", textTransform:"uppercase" }}>{c.category} · {c.year}</div>
                </div>
                <div style={{ display:"flex", gap:8 }}>
                  {["Edit","Preview","Unpublish"].map(a => (
                    <button key={a} style={{ background:"rgba(255,255,255,0.06)", color:"rgba(255,255,255,0.65)", border:"none", cursor:"pointer", padding:"6px 13px", borderRadius:4, fontSize:11, fontWeight:600 }}>{a}</button>
                  ))}
                  <button style={{ background:"rgba(255,60,60,0.12)", color:"#ff6b6b", border:"none", cursor:"pointer", padding:"6px 13px", borderRadius:4, fontSize:11, fontWeight:600 }}>Delete</button>
                </div>
              </div>
            ))}
          </div>
        )}

        {tab === "blog" && (
          <div>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:28 }}>
              <h1 style={{ fontSize:22, fontWeight:800 }}>Blog Posts</h1>
              <button style={{ background: BRAND.green, color:"#fff", border:"none", cursor:"pointer", padding:"9px 18px", borderRadius:4, fontWeight:700, fontSize:11, letterSpacing:"0.1em", textTransform:"uppercase" }}>+ New Post</button>
            </div>
            {BLOG_POSTS.map(p => (
              <div key={p.slug} style={{ background:"#1a1a1a", border:"1px solid rgba(255,255,255,0.06)", borderRadius:8, padding:"18px 22px", marginBottom:10, display:"flex", justifyContent:"space-between", alignItems:"center", flexWrap:"wrap", gap:10 }}>
                <div>
                  <div style={{ fontWeight:700, fontSize:14, marginBottom:3 }}>{p.title}</div>
                  <div style={{ fontSize:11, color:"rgba(255,255,255,0.35)" }}>{p.tag} · {p.date} · {p.readTime}</div>
                </div>
                <div style={{ display:"flex", gap:8 }}>
                  {["Edit","Unpublish"].map(a => (
                    <button key={a} style={{ background:"rgba(255,255,255,0.06)", color:"rgba(255,255,255,0.65)", border:"none", cursor:"pointer", padding:"6px 13px", borderRadius:4, fontSize:11, fontWeight:600 }}>{a}</button>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}

        {tab === "newsletter" && (
          <div>
            <h1 style={{ fontSize:22, fontWeight:800, marginBottom:8 }}>Newsletter Subscribers</h1>
            <p style={{ fontFamily:"Georgia, serif", color:"rgba(255,255,255,0.4)", fontStyle:"italic", fontSize:13, marginBottom:32 }}>Connect Supabase to manage and export subscribers.</p>
            <div style={{ background:"#1a1a1a", border:"1px solid rgba(10,90,47,0.15)", borderRadius:8, padding:"24px", textAlign:"center" }}>
              <div style={{ fontSize:36, marginBottom:12 }}>📧</div>
              <p style={{ fontFamily:"Georgia, serif", color:"rgba(255,255,255,0.4)", fontStyle:"italic", fontSize:14 }}>Subscriber data will appear here once Supabase is connected.</p>
            </div>
          </div>
        )}

        {(tab === "services" || tab === "settings") && (
          <div style={{ textAlign:"center", paddingTop:80 }}>
            <div style={{ fontSize:44, marginBottom:18 }}>◎</div>
            <h2 style={{ fontSize:20, fontWeight:700, marginBottom:12 }}>{tab.charAt(0).toUpperCase()+tab.slice(1)} Manager</h2>
            <p style={{ fontFamily:"Georgia, serif", color:"rgba(255,255,255,0.35)", fontStyle:"italic", maxWidth:400, margin:"0 auto", lineHeight:1.8, fontSize:14 }}>Connect Supabase to enable full {tab} editing without code. This panel is pre-structured and ready for backend integration.</p>
          </div>
        )}
      </div>
    </div>
  );
}

